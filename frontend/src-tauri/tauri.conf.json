{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",

  "productName": "Dentista App",
  "version": "2.5.0",
  "identifier": "com.dentista.app",

  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm start",
    "beforeBuildCommand": "npm run build"
  },

  "app": {
    "windows": [
      {
        "title": "Dentista App",
        "width": 900,
        "height": 650,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },

  "bundle": {
    "active": true,
    "targets": ["nsis"],   
    "icon": [
      "icons/v4_32.png",
      "icons/v4_48.png",
      "icons/v4_256.png",
      "icons/dentalapp.ico"
    ],

    
    "windows": {
      "digestAlgorithm": "sha256"
    }
  },

  "plugins": {
    
    }
}

